---
import { withBase } from '../lib/base';
import { getCategories, getCategoryCount, getIndex } from '../lib/data';
import { CATEGORY_BY_SLUG, CATEGORY_GROUPS } from '../lib/categories';
import { getCountryScenarios } from '../lib/countries';

interface Props {
  title: string;
  description?: string;
  activeType?: string;
}

const { title, description, activeType } = Astro.props;
const fullTitle = title === 'Solar Nations 2 Wiki' ? title : `${title} | Solar Nations 2 Wiki`;
const categories = getCategories().filter((category) => !category.mergedInto);
const activeCategoryGroup = activeType ? CATEGORY_BY_SLUG[activeType]?.group : undefined;
const categoryCounts = Object.fromEntries(categories.map((category) => [category.slug, getCategoryCount(category.slug)]));
const generatedDate = new Date(getIndex().generatedAt);
const buildLabel = Number.isNaN(generatedDate.valueOf())
  ? 'Current extraction'
  : `Updated ${generatedDate.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric', timeZone: 'Australia/Sydney' })}`;
const scenarioIds = getCountryScenarios().map((scenario) => scenario.id);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? 'Solar Nations 2 strategy and game data encyclopedia'} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{fullTitle}</title>
  </head>
  <body id="top">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="topbar">
      <a href={withBase('/')} class="brand" aria-label="Solar Nations 2 Wiki home">
        <span class="brand-mark" aria-hidden="true"></span>
        <span><strong>Solar Nations 2</strong><small>Strategy Wiki</small></span>
      </a>
      <div class="global-search" role="search">
        <label class="sr-only" for="global-search">Search the wiki</label>
        <span class="search-symbol" aria-hidden="true"></span>
        <input id="global-search" type="search" placeholder="Search technologies, factions, projects..." autocomplete="off" role="combobox" aria-autocomplete="list" aria-expanded="false" aria-controls="global-results" />
        <kbd>/</kbd>
        <div id="global-results" class="global-results" role="listbox" aria-label="Search results" hidden></div>
      </div>
      <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </header>

    <div class="site-frame">
      <button class="nav-backdrop" id="nav-backdrop" type="button" aria-label="Close navigation" tabindex="-1" hidden></button>
      <aside class="sidebar" id="sidebar" aria-label="Primary navigation">
        <nav aria-label="Wiki sections">
          <a href={withBase('/')} class:list={['nav-home', { active: !activeType }]}>Overview</a>
          {CATEGORY_GROUPS.map((group) => (
            <details class="nav-group" open={group.id !== 'reference' || activeCategoryGroup === group.id}>
              <summary>{group.label}</summary>
              <div>
                {categories.filter((cat) => cat.group === group.id).map((cat) => (
                  <a href={withBase(`/${cat.slug}/`)} class:list={{ active: activeType === cat.slug }}>
                    <span>{cat.pluralLabel}</span><small>{categoryCounts[cat.slug]}</small>
                  </a>
                ))}
              </div>
            </details>
          ))}
        </nav>
        <p class="sidebar-note">Game data reference<br />{buildLabel}</p>
      </aside>

      <main class="content"><span id="main-content" class="main-focus-target" tabindex="-1"></span><slot /></main>
    </div>

    <footer class="site-footer">
      <p>Unofficial Solar Nations 2 wiki. Game data belongs to Flomgus Games.</p>
      <a href="https://github.com/Mitchell-Swayn/Solar-Nations-Wiki">Source on GitHub</a>
    </footer>

    <script define:vars={{ baseUrl: import.meta.env.BASE_URL, scenarioIds }}>
      const input = document.getElementById('global-search');
      const results = document.getElementById('global-results');
      const toggle = document.getElementById('nav-toggle');
      const sidebar = document.getElementById('sidebar');
      const backdrop = document.getElementById('nav-backdrop');
      let activeResult = -1;
      let searchEntries = [];
      let searchEntriesPromise;

      const loadSearchEntries = () => {
        searchEntriesPromise ??= fetch(`${baseUrl}search-index.json`)
          .then((response) => {
            if (!response.ok) throw new Error(`Search index request failed with ${response.status}`);
            return response.json();
          })
          .then((loadedEntries) => (searchEntries = loadedEntries));
        return searchEntriesPromise;
      };

      const sidebarScrollKey = 'solar-nations-wiki:sidebar-scroll';
      const saveSidebarScroll = () => {
        if (!sidebar) return;
        try { sessionStorage.setItem(sidebarScrollKey, String(sidebar.scrollTop)); } catch { /* Storage may be unavailable. */ }
      };
      const restoreSidebarScroll = () => {
        if (!sidebar) return;
        try {
          const savedPosition = Number(sessionStorage.getItem(sidebarScrollKey));
          if (Number.isFinite(savedPosition)) sidebar.scrollTop = savedPosition;
        } catch { /* Storage may be unavailable. */ }
      };
      requestAnimationFrame(restoreSidebarScroll);
      sidebar?.addEventListener('scroll', saveSidebarScroll, { passive: true });
      sidebar?.addEventListener('click', (event) => { if (event.target.closest('a')) saveSidebarScroll(); }, { capture: true });
      window.addEventListener('pagehide', saveSidebarScroll);

      const validScenarios = new Set(scenarioIds);
      const activeScenario = () => {
        const requested = new URL(window.location.href).searchParams.get('scenario');
        if (requested && validScenarios.has(requested)) return requested;
        const selected = document.querySelector('[data-scenario-tabs] [data-scenario-id][aria-selected="true"]')?.dataset.scenarioId;
        return selected && validScenarios.has(selected) ? selected : undefined;
      };
      const syncScenarioLinks = () => {
        const scenario = activeScenario();
        if (!scenario) return;
        const current = new URL(window.location.href);
        if (current.searchParams.get('scenario') !== scenario) {
          current.searchParams.set('scenario', scenario);
          history.replaceState(history.state, '', current);
        }
        for (const link of document.querySelectorAll('a[href]')) {
          const rawHref = link.getAttribute('href');
          if (!rawHref || rawHref.startsWith('#')) continue;
          const url = new URL(rawHref, window.location.href);
          if (url.origin !== window.location.origin) continue;
          const targetScenario = link.dataset.scenarioId;
          url.searchParams.set('scenario', targetScenario && validScenarios.has(targetScenario) ? targetScenario : scenario);
          link.href = url.href;
        }
      };

      const escapeHtml = (value) => value.replace(/[&<>'"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' })[char]);
      const renderSearch = async () => {
        const query = input.value.trim().toLowerCase();
        if (query.length < 2) { results.hidden = true; input.setAttribute('aria-expanded', 'false'); activeResult = -1; return; }
        try {
          await loadSearchEntries();
        } catch {
          if (input.value.trim().toLowerCase() !== query) return;
          results.innerHTML = '<p>Search is temporarily unavailable</p>';
          results.hidden = false;
          input.setAttribute('aria-expanded', 'true');
          return;
        }
        if (input.value.trim().toLowerCase() !== query) return;
        const matches = searchEntries.filter((entry) => entry.name.toLowerCase().includes(query) || entry.id.toLowerCase().includes(query)).slice(0, 10);
        results.innerHTML = matches.length
          ? matches.map((entry, index) => `<a id="search-result-${index}" role="option" aria-selected="false" href="${baseUrl}${entry.path}"><span><strong>${escapeHtml(entry.name)}</strong><small>${escapeHtml(entry.id)}</small></span><em>${escapeHtml(entry.category)}</em></a>`).join('')
          : '<p>No matching entries</p>';
        results.hidden = false;
        input.setAttribute('aria-expanded', 'true');
        activeResult = -1;
        syncScenarioLinks();
      };
      input?.addEventListener('focus', () => { void loadSearchEntries(); }, { once: true });
      input?.addEventListener('input', () => { void renderSearch(); });
      input?.addEventListener('keydown', (event) => {
        const options = [...results.querySelectorAll('[role="option"]')];
        if ((event.key === 'ArrowDown' || event.key === 'ArrowUp') && options.length) {
          event.preventDefault();
          activeResult = event.key === 'ArrowDown' ? (activeResult + 1) % options.length : (activeResult - 1 + options.length) % options.length;
          options.forEach((option, index) => option.setAttribute('aria-selected', String(index === activeResult)));
          input.setAttribute('aria-activedescendant', options[activeResult].id);
          options[activeResult].scrollIntoView({ block: 'nearest' });
        }
        if (event.key === 'Enter' && activeResult >= 0) { event.preventDefault(); options[activeResult]?.click(); }
        if (event.key === 'Escape') { input.value = ''; results.hidden = true; input.setAttribute('aria-expanded', 'false'); input.removeAttribute('aria-activedescendant'); input.blur(); }
      });
      document.addEventListener('keydown', (event) => { if (event.key === '/' && document.activeElement !== input) { event.preventDefault(); input?.focus(); } });
      document.addEventListener('click', (event) => { if (!event.target.closest('.global-search')) { results.hidden = true; input.setAttribute('aria-expanded', 'false'); } });
      const setNavigation = (open) => {
        sidebar.classList.toggle('open', open);
        toggle.classList.toggle('open', open);
        toggle.setAttribute('aria-expanded', String(open));
        backdrop.hidden = !open;
        document.body.classList.toggle('nav-open', open);
        if (open) sidebar.querySelector('a')?.focus();
      };
      toggle?.addEventListener('click', () => setNavigation(!sidebar.classList.contains('open')));
      backdrop?.addEventListener('click', () => { setNavigation(false); toggle.focus(); });
      sidebar?.addEventListener('click', (event) => { if (event.target.closest('a') && window.innerWidth <= 820) setNavigation(false); });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && sidebar.classList.contains('open')) { setNavigation(false); toggle.focus(); }
        if (event.key === 'Tab' && sidebar.classList.contains('open')) {
          const focusable = [...sidebar.querySelectorAll('a, button, input, select, [tabindex]:not([tabindex="-1"])')];
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (event.shiftKey && document.activeElement === first) { event.preventDefault(); last?.focus(); }
          if (!event.shiftKey && document.activeElement === last) { event.preventDefault(); first?.focus(); }
        }
      });
      document.addEventListener('click', (event) => {
        if (event.target.closest('[data-scenario-id]')) setTimeout(syncScenarioLinks, 0);
      });
      window.addEventListener('popstate', () => setTimeout(syncScenarioLinks, 0));
      syncScenarioLinks();

      const updateAdaptiveImageLoading = () => {
        for (const image of document.querySelectorAll('img[data-auto-loading]')) {
          let element = image;
          let documentTop = 0;
          while (element) {
            documentTop += element.offsetTop;
            element = element.offsetParent;
          }
          image.loading = documentTop < window.innerHeight ? 'eager' : 'lazy';
        }
      };
      updateAdaptiveImageLoading();
      window.addEventListener('resize', updateAdaptiveImageLoading, { passive: true });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
