---
import { withBase } from '../lib/base';
import manifest from '../../data/curated/icon-manifest.json';

interface Props {
  name: string;
  size?: number;
}

const { name, size = 32 } = Astro.props;
const path = (manifest as Record<string, string>)[name.toLowerCase()] ?? `${name}.png`;
const src = withBase(`/wiki-icons/${path}`);
---

<img
  src={src}
  alt=""
  width={size}
  height={size}
  class="game-icon"
  onerror="this.style.display='none'"
/>

<style>
  .game-icon {
    object-fit: contain;
    vertical-align: middle;
    border-radius: 4px;
  }
</style>
