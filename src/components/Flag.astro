---
interface Props {
  name: string;
  size?: number;
}

const { name, size = 48 } = Astro.props;
const src = `/assets/flags/${name}.png`;
---

<img
  src={src}
  alt={`${name} flag`}
  width={size}
  height={Math.round(size * 0.67)}
  class="flag"
  onerror="this.style.display='none'"
/>

<style>
  .flag {
    object-fit: contain;
    border: 1px solid var(--border);
    border-radius: 2px;
  }
</style>
