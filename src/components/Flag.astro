---
import { withBase } from '../lib/base';

interface Props {
  name: string;
  size?: number;
  loading?: 'eager' | 'lazy';
}

const { name, size = 48, loading } = Astro.props;
const src = withBase(`/assets/flags/${name}.png`);
const adaptiveLoading = loading === undefined;
---

<img
  src={src}
  alt={`${name} flag`}
  width={size}
  height={Math.round(size * 0.67)}
  class="flag"
  loading={loading ?? 'lazy'}
  decoding="async"
  data-auto-loading={adaptiveLoading || undefined}
  onerror="this.style.display='none'"
/>

<style>
  .flag {
    object-fit: contain;
    border: 1px solid var(--border);
    border-radius: 2px;
  }
</style>
