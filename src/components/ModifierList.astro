---
import type { ModifierRef } from '../lib/types';
import { getEntry, getModifierMap, getModifierTargetIcon } from '../lib/data';
import { withBase } from '../lib/base';
import GameIcon from './GameIcon.astro';

interface Props {
  modifiers: ModifierRef[];
}

const { modifiers } = Astro.props;
const modifierMap = getModifierMap();
const showScope = modifiers.some((modifier) => modifier.scope);

function formatValue(mod: ModifierRef): string {
  const def = modifierMap.get(mod.key);
  const val = mod.value;
  if (typeof val !== 'number') return String(val);
  if (def?.IsPercent === 'Percentage') {
    return `${val >= 0 ? '+' : ''}${(val * 100).toFixed(1)}%`;
  }
  return `${val >= 0 ? '+' : ''}${val}`;
}

function formatName(mod: ModifierRef): string {
  const def = modifierMap.get(mod.key);
  if ((mod.key === 'resourceModifier' || mod.key.startsWith('resourceCapacity')) && mod.value1) {
    return getEntry('resources', mod.value1)?.displayName ?? getEntry('deposit-resources', mod.value1)?.displayName ?? mod.value1;
  }
  if (mod.key === 'factionVariant' && mod.value1 && mod.value2) {
    const humanize = (value: string) => value
      .replace(/([a-z])([A-Z])/g, '$1 $2')
      .replace(/_/g, ' ')
      .replace(/^./, (character) => character.toUpperCase());
    const faction = getEntry('factions', mod.value1)?.displayName ?? humanize(mod.value1);
    const variant = getEntry('faction-variants', mod.value2)?.displayName ?? humanize(mod.value2);
    return `Enables ${faction} Variant: ${variant}`;
  }
  const targetFirstLabel = mod.key === 'politicalPowerAdd' ? 'Political Power'
    : mod.key === 'factionPowerAdd' ? 'Faction Power'
    : mod.key === 'factionLoyaltyAdd' ? 'Faction Loyalty'
    : undefined;
  if (!targetFirstLabel || !mod.value1) return def?.DisplayName ?? mod.key;
  const faction = getEntry('factions', mod.value1)?.displayName ?? mod.value1
    .replace(/([a-z])([A-Z])/g, '$1 $2')
    .replace(/_/g, ' ')
    .replace(/^./, (character) => character.toUpperCase());
  return `${faction} ${targetFirstLabel}`;
}

function formatTarget(mod: ModifierRef): string {
  if (mod.key === 'politicalPowerAdd' || mod.key === 'factionPowerAdd' || mod.key === 'factionLoyaltyAdd' || mod.key === 'factionVariant' || mod.key === 'resourceModifier' || mod.key.startsWith('resourceCapacity')) return '';
  const parts = [mod.value1, mod.value2, mod.value3].filter(Boolean);
  return parts.length ? ` (${parts.join(', ')})` : '';
}
---

{modifiers.length > 0 ? (
  <table class="modifier-table">
    <thead>
      <tr>
        <th>Modifier</th>
        <th>Value</th>
        <th>Target</th>
        {showScope && <th>Scope</th>}
      </tr>
    </thead>
    <tbody>
      {modifiers.map((mod) => {
        const def = modifierMap.get(mod.key);
        const targetIcon = getModifierTargetIcon(mod.value1);
        return (
          <tr>
            <td>
              <span class="modifier-name">
                {def?.Icon && <GameIcon name={def.Icon} size={20} />}
                {targetIcon && targetIcon !== def?.Icon && <GameIcon name={targetIcon} size={20} />}
                <a href={withBase(`/modifiers/${mod.key}/`)}>{formatName(mod)}</a>
              </span>
            </td>
            <td class={def?.Positivity === 'positive' ? 'positive' : def?.Positivity === 'negative' ? 'negative' : ''}>
              {formatValue(mod)}
            </td>
            <td class="target">{formatTarget(mod)}</td>
            {showScope && <td class="scope">{mod.scope ?? 'General'}</td>}
          </tr>
        );
      })}
    </tbody>
  </table>
) : (
  <p class="empty">No modifiers.</p>
)}

<style>
  .modifier-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .modifier-table th,
  .modifier-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    text-align: left;
  }
  .modifier-name {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .positive { color: var(--positive); }
  .negative { color: var(--negative); }
  .target { color: var(--text-muted); font-size: 0.85rem; }
  .scope { color: var(--text-muted); font-size: 0.78rem; font-weight: 600; text-transform: uppercase; }
  .empty { color: var(--text-muted); }
</style>
