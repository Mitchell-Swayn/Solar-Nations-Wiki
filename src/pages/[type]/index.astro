---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import GameIcon from '../../components/GameIcon.astro';
import CountryFlagIcon from '../../components/CountryFlagIcon.astro';
import ModifierBadges from '../../components/ModifierBadges.astro';
import CharacterJobSkillBadges from '../../components/CharacterJobSkillBadges.astro';
import ScenarioTabs from '../../components/ScenarioTabs.astro';
import { getCategories, getEntriesByType } from '../../lib/data';
import { CATEGORY_BY_SLUG, CATEGORY_GROUPS } from '../../lib/categories';
import { getCultureTraitGroup, isCultureFamilyRoot } from '../../lib/culture';
import { getCountryScenarios, getCultureIconCountry } from '../../lib/countries';
import { withBase } from '../../lib/base';

export function getStaticPaths() {
  return getCategories().filter((cat) => cat.slug !== 'countries').map((cat) => ({ params: { type: cat.slug } }));
}

const { type } = Astro.params;
const category = CATEGORY_BY_SLUG[type!];
if (category.mergedInto) return Astro.redirect(withBase(`/${category.mergedInto}/`));
const entries = getEntriesByType(type!).sort((a, b) => a.displayName.localeCompare(b.displayName));
const group = CATEGORY_GROUPS.find((item) => item.id === category.group);
const GOVERNMENT_REFORM_GAME_ORDER = [
  'form', 'economySystem', 'civilLiberties', 'militaryDoctrine', 'espionagePolicy',
  'nationalFocus', 'serviceLaw', 'educationLaw', 'tradePolicy', 'roboticsLaw',
  'nanocompositeLaw', 'adminStance', 'migrationLaw', 'governmentSpending',
  'fiscalPolicy', 'welfareSpending', 'espionageFunding', 'colonyPolicy',
];
const reforms = type === 'government-reforms' ? [
  ...GOVERNMENT_REFORM_GAME_ORDER.flatMap((id) => entries.filter((entry) => entry.id === id)),
  ...entries.filter((entry) => !GOVERNMENT_REFORM_GAME_ORDER.includes(entry.id)),
] : [];
const reformOptionEntries = type === 'government-reforms' ? getEntriesByType('government-reform-options').sort((a, b) => a.displayName.localeCompare(b.displayName)) : [];
const reformGroups = reforms.map((reform) => {
  const optionIds = Array.isArray(reform.fields.Options) ? reform.fields.Options.filter((id): id is string => typeof id === 'string') : [];
  return { reform, options: optionIds.map((id) => reformOptionEntries.find((entry) => entry.id === id)).filter((entry) => entry !== undefined) };
});
const governmentReformSections = type === 'government-reforms' ? [
  { id: 'politics', label: 'Politics', groups: reformGroups.filter(({ reform }) => reform.fields.IsPolitical === 'Politics') },
  { id: 'policies', label: 'Policies', groups: reformGroups.filter(({ reform }) => reform.fields.IsPolitical !== 'Politics') },
].filter((section) => section.groups.length > 0) : [];
const factionVariants = type === 'factions' ? getEntriesByType('faction-variants').sort((a, b) => a.displayName.localeCompare(b.displayName)) : [];
const factionGroups = type === 'factions' ? entries.map((faction) => ({
  faction,
  variants: factionVariants.filter((variant) => variant.fields.BaseFaction === faction.id),
})) : [];
const privilegeFactions = type === 'faction-privileges' ? getEntriesByType('factions') : [];
const factionPrivilegeGroups = type === 'faction-privileges' ? [
  { faction: undefined, id: 'all', label: 'All Factions', entries: entries.filter((entry) => entry.fields.Faction === 'all') },
  ...privilegeFactions.map((faction) => ({
    faction,
    id: faction.id,
    label: faction.displayName,
    entries: entries.filter((entry) => entry.fields.Faction === faction.id),
  })),
].filter((privilegeGroup) => privilegeGroup.entries.length > 0) : [];
const characterTraitGroups = type === 'character-traits' ? [
  { id: 'general', label: 'General' },
  { id: 'strategy', label: 'Strategy' },
  { id: 'management', label: 'Management' },
  { id: 'charisma', label: 'Charisma' },
  { id: 'subversive', label: 'Subversive' },
].map((traitCategory) => ({
  ...traitCategory,
  entries: entries.filter((entry) => entry.fields.Category === traitCategory.id),
})).filter((traitCategory) => traitCategory.entries.length > 0) : [];
const characterJobGroups = type === 'character-jobs' ? [
  { id: 'ruler', label: 'Ruler' },
  { id: 'economyMinister', label: 'Economy Minister' },
  { id: 'interiorMinister', label: 'Interior Minister' },
  { id: 'defenseMinister', label: 'Defense Minister' },
  { id: 'unitCommander', label: 'Commander' },
  { id: 'governRegion', label: 'Governor' },
  { id: 'spymaster', label: 'Spymaster' },
].map((jobArchetype) => ({
  ...jobArchetype,
  entries: entries.filter((entry) => entry.fields.JobArchetype === jobArchetype.id),
})).filter((jobArchetype) => jobArchetype.entries.length > 0) : [];
const cultureGroups = type === 'culture-traits' ? Object.values(entries.reduce((groups, entry) => {
  const meta = getCultureTraitGroup(entry.id);
  groups[meta.id] ??= { meta, entries: [] };
  groups[meta.id].entries.push(entry);
  return groups;
}, {} as Record<string, { meta: ReturnType<typeof getCultureTraitGroup>; entries: typeof entries }>)) : [];
const cultureSubgroupDefinitions = [
  { id: 'general', value: 'None', label: 'General' },
  { id: 'administrative', value: 'administrative', label: 'Administrative' },
  { id: 'diplomatic', value: 'diplomatic', label: 'Diplomatic' },
  { id: 'economic', value: 'economic', label: 'Economic' },
  { id: 'military', value: 'military', label: 'Military' },
];
const cultureDomains = ['Species', 'Religion', 'Heritage', 'Idea', 'Special'].map((domain) => ({
  domain,
  subgroups: cultureSubgroupDefinitions.map((subgroup) => ({
    ...subgroup,
    groups: cultureGroups.filter((cultureGroup) => {
      const root = cultureGroup.entries.find((entry) => isCultureFamilyRoot(entry.id));
      const listCategory = typeof root?.fields.ListCategory === 'string' ? root.fields.ListCategory : 'None';
      return cultureGroup.meta.domain === domain && listCategory === subgroup.value;
    }).sort((a, b) => a.meta.label.localeCompare(b.meta.label)),
  })).filter((subgroup) => subgroup.groups.length > 0),
})).filter((domain) => domain.subgroups.length > 0);
const CULTURE_TECHNOLOGIES = new Set([
  'commerceZones', 'eraInterplanetary', 'eraUnification', 'futureSociety',
  'militaryDoctrine_mobile', 'solarFederation', 'warExpansion',
]);
const MILITARY_TECHNOLOGY = /^(airplanes|armor|artillery|autocannon|empTurret|engine|laserTurret|missile|radiator|smallArms|spaceHull|tank|turret)\d+$|^(biohazard|colossalCommandCenter|flyingFortress|magneticShield|polarizedArmor|spacedArmor)$/;
const technologyDomains = type === 'technologies' ? [
  { id: 'defaultDomain', label: 'Technology', entries: entries.filter((entry) => !CULTURE_TECHNOLOGIES.has(entry.id) && !MILITARY_TECHNOLOGY.test(entry.id)) },
  { id: 'militaryTech', label: 'Military Technology', entries: entries.filter((entry) => MILITARY_TECHNOLOGY.test(entry.id)) },
  { id: 'culture', label: 'Culture', entries: entries.filter((entry) => CULTURE_TECHNOLOGIES.has(entry.id)) },
].filter((domain) => domain.entries.length > 0) : [];
function componentFamilyLabel(id: string) {
  const label = id.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/^./, (character) => character.toUpperCase());
  return label.replace(/\b(Apc|Atgm|Emp)\b/g, (acronym) => acronym.toUpperCase());
}
const componentFamilies = type === 'unit-components' ? Object.values(entries.reduce((families, entry) => {
  const id = entry.id.replace(/_?\d+$/, '');
  families[id] ??= { id, label: componentFamilyLabel(id), entries: [] };
  families[id].entries.push(entry);
  return families;
}, {} as Record<string, { id: string; label: string; entries: typeof entries }>)).map((family) => ({
  ...family,
  entries: family.entries.sort((a, b) => a.id.localeCompare(b.id, undefined, { numeric: true, sensitivity: 'base' })),
})).sort((a, b) => a.id.localeCompare(b.id, undefined, { numeric: true, sensitivity: 'base' })) : [];
const cultureIndexScenarios = type === 'cultures' ? getCountryScenarios() : [];
const cultureIndexTabs = cultureIndexScenarios.map((scenario) => ({
  id: scenario.id,
  label: scenario.name,
  href: `?scenario=${scenario.id}`,
}));
const directoryCount = reformGroups.length > 0 ? reformOptionEntries.length : factionGroups.length > 0 ? factionVariants.length + entries.length : entries.length;
---

<BaseLayout title={category.pluralLabel} description={category.description} activeType={type}>
  <Breadcrumbs group={group?.label} category={category.pluralLabel} />

  <header class="collection-header">
    <div><p class="eyebrow">{group?.label}</p><h1>{category.pluralLabel}</h1><p>{category.description}</p></div>
    <div class="collection-count"><strong>{directoryCount}</strong><span>{reformGroups.length > 0 ? `${reforms.length} reforms` : factionGroups.length > 0 ? `${entries.length} factions` : 'Entries'}</span></div>
  </header>

  {cultureIndexTabs.length > 0 && <ScenarioTabs tabs={cultureIndexTabs} switchPanels />}

  {cultureDomains.length > 0 && (
    <nav class="culture-index" aria-labelledby="culture-index-title">
      <h2 id="culture-index-title">Contents</h2>
      <ol>
        {cultureDomains.map(({ domain, subgroups }) => (
          <li>
            <a class="culture-index-domain" href={`#culture-domain-${domain.toLowerCase()}`}>{domain}</a>
            <ol>
              {subgroups.map(({ id: subgroupId, label, groups }) => (
                <li>
                  <a class="culture-index-subgroup" href={`#culture-subgroup-${domain.toLowerCase()}-${subgroupId}`}>{label}</a>
                  <ol>
                    {groups.map(({ meta }) => (
                      <li><a class="culture-index-family" href={`#trait-family-${meta.id}`}><GameIcon name={meta.icon} size={18} /><span>{meta.label}</span></a></li>
                    ))}
                  </ol>
                </li>
              ))}
            </ol>
          </li>
        ))}
      </ol>
    </nav>
  )}

  <div class="collection-tools">
    <label class="filter-input"><span class="sr-only">Filter {category.pluralLabel.toLowerCase()}</span><span class="search-symbol"></span><input id="entry-filter" type="search" placeholder={`Filter ${category.pluralLabel.toLowerCase()}...`} /></label>
    <span id="visible-count">Showing {directoryCount}</span>
  </div>

  {governmentReformSections.length > 0 ? (
    <div class="grouped-directory government-reform-directory" id="entry-directory">
      {governmentReformSections.map((reformSection) => (
        <section class="government-reform-kind" id={`government-reforms-${reformSection.id}`}>
          <header><p class="eyebrow">Government</p><h2>{reformSection.label}</h2></header>
          {reformSection.groups.map(({ reform, options }) => (
            <section class="reform-option-group entry-group">
              <header><div><h3>{reform.displayName}</h3></div><a href={withBase(`/government-reforms/${reform.id}/`)}>View reform</a></header>
              <div class="entry-directory">
                {options.map((entry) => (
                  <a href={withBase(`/government-reform-options/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${reformSection.label} ${reform.displayName} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                    <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                    <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                    <ModifierBadges modifiers={entry.modifiers} />
                    <span class="row-arrow" aria-hidden="true">›</span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </section>
      ))}
    </div>
  ) : factionGroups.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {factionGroups.map(({ faction, variants }) => (
        <section class="reform-option-group entry-group">
          <header><div class="culture-family-title">{faction.icon && <GameIcon name={faction.icon} size={30} />}<div><p class="eyebrow">Political Faction</p><h2>{faction.displayName}</h2></div></div><a href={withBase(`/factions/${faction.id}/`)}>View faction</a></header>
          <div class="entry-directory">
            <a href={withBase(`/factions/${faction.id}/`)} class:list={['directory-row', { 'with-effects': faction.modifiers.length > 0 }]} data-search={`${faction.displayName} ${faction.id}`.toLowerCase()}>
              <span class="directory-icon">{faction.icon ? <GameIcon name={faction.icon} size={34} /> : <span>{faction.displayName.charAt(0)}</span>}</span>
              <span class="directory-main"><strong>{faction.displayName}</strong><code>{faction.id}</code>{faction.description && <small>{faction.description}</small>}</span>
              <ModifierBadges modifiers={faction.modifiers} />
              <span class="row-arrow" aria-hidden="true">›</span>
            </a>
            {variants.map((variant) => (
              <a href={withBase(`/faction-variants/${variant.id}/`)} class:list={['directory-row', { 'with-effects': variant.modifiers.length > 0 }]} data-search={`${faction.displayName} ${variant.displayName} ${variant.id}`.toLowerCase()}>
                <span class="directory-icon">{variant.icon ? <GameIcon name={variant.icon} size={34} /> : <span>{variant.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{variant.displayName}</strong><code>{variant.id}</code>{variant.description && <small>{variant.description}</small>}</span>
                <ModifierBadges modifiers={variant.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : factionPrivilegeGroups.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {factionPrivilegeGroups.map((privilegeGroup) => (
        <section class="reform-option-group entry-group">
          <header>
            <div class="culture-family-title">
              {privilegeGroup.faction?.icon && <GameIcon name={privilegeGroup.faction.icon} size={30} />}
              <div><p class="eyebrow">Faction</p><h2>{privilegeGroup.label}</h2></div>
            </div>
            {privilegeGroup.faction && <a href={withBase(`/factions/${privilegeGroup.faction.id}/`)}>View faction</a>}
          </header>
          <div class="entry-directory">
            {privilegeGroup.entries.map((entry) => (
              <a href={withBase(`/faction-privileges/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${privilegeGroup.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <ModifierBadges modifiers={entry.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : componentFamilies.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {componentFamilies.map((family) => (
        <section class="reform-option-group entry-group">
          <header><div><p class="eyebrow">Component Family</p><h2>{family.label}</h2></div><span>{family.entries.length} component{family.entries.length === 1 ? '' : 's'}</span></header>
          <div class="entry-directory">
            {family.entries.map((entry) => (
              <a href={withBase(`/unit-components/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${family.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <ModifierBadges modifiers={entry.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : characterTraitGroups.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {characterTraitGroups.map((traitGroup) => (
        <section class="reform-option-group entry-group">
          <header><div><p class="eyebrow">Character Trait Category</p><h2>{traitGroup.label}</h2></div><span>{traitGroup.entries.length} trait{traitGroup.entries.length === 1 ? '' : 's'}</span></header>
          <div class="entry-directory">
            {traitGroup.entries.map((entry) => (
              <a href={withBase(`/character-traits/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${traitGroup.label} ${entry.fields.Category ?? ''} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <ModifierBadges modifiers={entry.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : characterJobGroups.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {characterJobGroups.map((jobGroup) => (
        <section class="reform-option-group entry-group">
          <header><div><p class="eyebrow">Job Archetype</p><h2>{jobGroup.label}</h2></div><span>{jobGroup.entries.length} job{jobGroup.entries.length === 1 ? '' : 's'}</span></header>
          <div class="entry-directory">
            {jobGroup.entries.map((entry) => (
              <a href={withBase(`/character-jobs/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 || entry.skillModifiers }]} data-search={`${jobGroup.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <span class="character-job-effects">
                  <ModifierBadges modifiers={entry.modifiers} />
                  {entry.skillModifiers && <CharacterJobSkillBadges skillModifiers={entry.skillModifiers} />}
                </span>
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : technologyDomains.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {technologyDomains.map((domain) => (
        <section class="reform-option-group entry-group">
          <header><div><p class="eyebrow">Technology Domain</p><h2>{domain.label}</h2></div></header>
          <div class="entry-directory">
            {domain.entries.map((entry) => (
              <a href={withBase(`/technologies/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${domain.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <ModifierBadges modifiers={entry.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : cultureDomains.length > 0 ? (
    <div class="grouped-directory culture-directory" id="entry-directory">
      {cultureDomains.map(({ domain, subgroups }) => (
        <section class="culture-domain" id={`culture-domain-${domain.toLowerCase()}`}>
          <header><p class="eyebrow">Culture Domain</p><h2>{domain}</h2></header>
          {subgroups.map(({ id: subgroupId, label, groups }) => (
            <section class="culture-subgroup" id={`culture-subgroup-${domain.toLowerCase()}-${subgroupId}`}>
              <header><p class="eyebrow">Trait Family Group</p><h3>{label}</h3></header>
              {groups.map(({ meta, entries: familyEntries }) => (
                <section class="reform-option-group culture-family entry-group" id={`trait-family-${meta.id}`}>
                  <header><div class="culture-family-title"><GameIcon name={meta.icon} size={30} /><div><p class="eyebrow">Trait Family</p><h4>{meta.label}</h4></div></div><a href={withBase(`/culture-traits/${meta.id}/`)}>View family</a></header>
                  <div class="entry-directory">
                    {[...familyEntries].sort((a, b) => Number(isCultureFamilyRoot(b.id)) - Number(isCultureFamilyRoot(a.id)) || Number(a.fields.IdeaIndex ?? 0) - Number(b.fields.IdeaIndex ?? 0)).map((entry) => (
                      <a href={withBase(`/culture-traits/${meta.id}/#${entry.id}`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${domain} ${label} ${meta.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                        <span class="directory-icon"><GameIcon name={entry.icon ?? meta.icon} size={34} /></span>
                        <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                        <ModifierBadges modifiers={entry.modifiers} />
                        <span class="row-arrow" aria-hidden="true">›</span>
                      </a>
                    ))}
                  </div>
                </section>
              ))}
            </section>
          ))}
        </section>
      ))}
    </div>
  ) : (
    <div class="entry-directory" id="entry-directory">
      {entries.map((entry) => {
        const cultureIconStates = cultureIndexScenarios.map((scenario) => ({
          scenarioId: scenario.id,
          country: getCultureIconCountry(entry.id, scenario.id),
        }));
        return (
          <a href={withBase(`/${type}/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0, 'planetary-body-row': type === 'planetary-bodies' }]} data-search={`${entry.displayName} ${entry.id}`.toLowerCase()}>
            <span class="directory-icon">
              {type === 'cultures' ? cultureIconStates.map((state, index) => (
                <span data-scenario-panel={state.scenarioId} hidden={index > 0}>{state.country ? <CountryFlagIcon flag={state.country.flag} countryName={state.country.name} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
              )) : entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}
            </span>
            <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && !(type === 'resources' && entry.id === 'manpower') && <small>{entry.description}</small>}</span>
            <ModifierBadges modifiers={entry.modifiers} showScalingScope={type === 'resources'} />
            <span class="row-arrow" aria-hidden="true">›</span>
          </a>
        );
      })}
    </div>
  )}
  <p class="empty-state" id="empty-state" hidden>No entries match this filter.</p>
</BaseLayout>

<script>
  const filter = document.getElementById('entry-filter') as HTMLInputElement;
  const rows = [...document.querySelectorAll<HTMLElement>('.directory-row')];
  const count = document.getElementById('visible-count');
  const empty = document.getElementById('empty-state');
  const updateRows = () => {
    const query = filter.value.trim().toLowerCase();
    let visible = 0;
    rows.forEach((row) => {
      const matchesText = row.dataset.search?.includes(query) ?? false;
      const show = matchesText;
      row.hidden = !show;
      if (show) visible++;
    });
    document.querySelectorAll<HTMLElement>('.entry-group').forEach((group) => { group.hidden = !group.querySelector('.directory-row:not([hidden])'); });
    document.querySelectorAll<HTMLElement>('.government-reform-kind').forEach((group) => { group.hidden = !group.querySelector('.entry-group:not([hidden])'); });
    document.querySelectorAll<HTMLElement>('.culture-subgroup').forEach((subgroup) => { subgroup.hidden = !subgroup.querySelector('.entry-group:not([hidden])'); });
    document.querySelectorAll<HTMLElement>('.culture-domain').forEach((domain) => { domain.hidden = !domain.querySelector('.culture-subgroup:not([hidden])'); });
    if (count) count.textContent = `Showing ${visible}`;
    if (empty) empty.hidden = visible > 0;
  };
  filter?.addEventListener('input', updateRows);
</script>

