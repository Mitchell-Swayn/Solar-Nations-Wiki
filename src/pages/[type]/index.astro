---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameIcon from '../../components/GameIcon.astro';
import ModifierBadges from '../../components/ModifierBadges.astro';
import { getCategories, getEntriesByType } from '../../lib/data';
import { CATEGORY_BY_SLUG, CATEGORY_GROUPS } from '../../lib/categories';
import { getCultureTraitGroup, isCultureFamilyRoot } from '../../lib/culture';
import { withBase } from '../../lib/base';

export function getStaticPaths() {
  return getCategories().map((cat) => ({ params: { type: cat.slug } }));
}

const { type } = Astro.params;
const category = CATEGORY_BY_SLUG[type!];
if (category.mergedInto) return Astro.redirect(withBase(`/${category.mergedInto}/`));
const entries = getEntriesByType(type!).sort((a, b) => a.displayName.localeCompare(b.displayName));
const group = CATEGORY_GROUPS.find((item) => item.id === category.group);
const reforms = type === 'government-reforms' ? entries : [];
const reformOptionEntries = type === 'government-reforms' ? getEntriesByType('government-reform-options').sort((a, b) => a.displayName.localeCompare(b.displayName)) : [];
const reformGroups = reforms.map((reform) => {
  const optionIds = Array.isArray(reform.fields.Options) ? reform.fields.Options.filter((id): id is string => typeof id === 'string') : [];
  return { reform, options: optionIds.map((id) => reformOptionEntries.find((entry) => entry.id === id)).filter((entry) => entry !== undefined) };
});
const factionVariants = type === 'factions' ? getEntriesByType('faction-variants').sort((a, b) => a.displayName.localeCompare(b.displayName)) : [];
const factionGroups = type === 'factions' ? entries.map((faction) => ({
  faction,
  variants: factionVariants.filter((variant) => variant.fields.BaseFaction === faction.id),
})) : [];
const cultureGroups = type === 'culture-traits' ? Object.values(entries.reduce((groups, entry) => {
  const meta = getCultureTraitGroup(entry.id);
  groups[meta.id] ??= { meta, entries: [] };
  groups[meta.id].entries.push(entry);
  return groups;
}, {} as Record<string, { meta: ReturnType<typeof getCultureTraitGroup>; entries: typeof entries }>)) : [];
const cultureDomains = ['Species & Faith', 'Cultural', 'Economic', 'Diplomatic', 'Administrative', 'Military'].map((domain) => ({
  domain,
  groups: cultureGroups.filter((cultureGroup) => cultureGroup.meta.domain === domain).sort((a, b) => a.meta.label.localeCompare(b.meta.label)),
})).filter((domain) => domain.groups.length > 0);
const CULTURE_TECHNOLOGIES = new Set([
  'commerceZones', 'eraInterplanetary', 'eraUnification', 'futureSociety',
  'militaryDoctrine_mobile', 'solarFederation', 'warExpansion',
]);
const MILITARY_TECHNOLOGY = /^(airplanes|armor|artillery|autocannon|empTurret|engine|laserTurret|missile|radiator|smallArms|spaceHull|tank|turret)\d+$|^(biohazard|colossalCommandCenter|flyingFortress|magneticShield|polarizedArmor|spacedArmor)$/;
const technologyDomains = type === 'technologies' ? [
  { id: 'defaultDomain', label: 'Technology', entries: entries.filter((entry) => !CULTURE_TECHNOLOGIES.has(entry.id) && !MILITARY_TECHNOLOGY.test(entry.id)) },
  { id: 'militaryTech', label: 'Military Technology', entries: entries.filter((entry) => MILITARY_TECHNOLOGY.test(entry.id)) },
  { id: 'culture', label: 'Culture', entries: entries.filter((entry) => CULTURE_TECHNOLOGIES.has(entry.id)) },
].filter((domain) => domain.entries.length > 0) : [];
function componentFamilyLabel(id: string) {
  const label = id.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/^./, (character) => character.toUpperCase());
  return label.replace(/\b(Apc|Atgm|Emp)\b/g, (acronym) => acronym.toUpperCase());
}
const componentFamilies = type === 'unit-components' ? Object.values(entries.reduce((families, entry) => {
  const id = entry.id.replace(/_?\d+$/, '');
  families[id] ??= { id, label: componentFamilyLabel(id), entries: [] };
  families[id].entries.push(entry);
  return families;
}, {} as Record<string, { id: string; label: string; entries: typeof entries }>)).sort((a, b) => a.label.localeCompare(b.label)) : [];
const directoryCount = reformGroups.length > 0 ? reformOptionEntries.length : factionGroups.length > 0 ? factionVariants.length + entries.length : entries.length;
---

<BaseLayout title={category.pluralLabel} description={category.description} activeType={type}>
  <nav class="breadcrumb" aria-label="Breadcrumb"><a href={withBase('/')}>Wiki</a><span>/</span><span>{group?.label}</span><span>/</span><strong>{category.pluralLabel}</strong></nav>

  <header class="collection-header">
    <div><p class="eyebrow">{group?.label}</p><h1>{category.pluralLabel}</h1><p>{category.description}</p></div>
    <div class="collection-count"><strong>{directoryCount}</strong><span>{reformGroups.length > 0 ? `${reforms.length} reforms` : factionGroups.length > 0 ? `${entries.length} factions` : 'Entries'}</span></div>
  </header>

  <div class="collection-tools">
    <label class="filter-input"><span class="search-symbol"></span><input id="entry-filter" type="search" placeholder={`Filter ${category.pluralLabel.toLowerCase()}...`} /></label>
    <label class="tool-select"><span class="sr-only">Filter by entry type</span><select id="entry-kind"><option value="all">All entries</option><option value="effects">With effects</option></select></label>
    <div class="view-switch" aria-label="View density">
      <button type="button" class="active" data-view="comfortable" aria-pressed="true">List</button><button type="button" data-view="compact" aria-pressed="false">Compact</button>
    </div>
    <label class="id-toggle"><input id="show-ids" type="checkbox" checked /> IDs</label>
    <span id="visible-count">Showing {directoryCount}</span>
  </div>

  {reformGroups.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {reformGroups.map(({ reform, options }) => (
        <section class="reform-option-group entry-group">
          <header><div><p class="eyebrow">Government Reform</p><h2>{reform.displayName}</h2></div><a href={withBase(`/government-reforms/${reform.id}/`)}>View reform</a></header>
          <div class="entry-directory">
            {options.map((entry) => (
              <a href={withBase(`/government-reform-options/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${reform.displayName} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <ModifierBadges modifiers={entry.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : factionGroups.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {factionGroups.map(({ faction, variants }) => (
        <section class="reform-option-group entry-group">
          <header><div class="culture-family-title">{faction.icon && <GameIcon name={faction.icon} size={30} />}<div><p class="eyebrow">Political Faction</p><h2>{faction.displayName}</h2></div></div><a href={withBase(`/factions/${faction.id}/`)}>View faction</a></header>
          <div class="entry-directory">
            <a href={withBase(`/factions/${faction.id}/`)} class:list={['directory-row', { 'with-effects': faction.modifiers.length > 0 }]} data-search={`${faction.displayName} ${faction.id}`.toLowerCase()}>
              <span class="directory-icon">{faction.icon ? <GameIcon name={faction.icon} size={34} /> : <span>{faction.displayName.charAt(0)}</span>}</span>
              <span class="directory-main"><strong>{faction.displayName}</strong><code>{faction.id}</code>{faction.description && <small>{faction.description}</small>}</span>
              <ModifierBadges modifiers={faction.modifiers} />
              <span class="row-arrow" aria-hidden="true">›</span>
            </a>
            {variants.map((variant) => (
              <a href={withBase(`/faction-variants/${variant.id}/`)} class:list={['directory-row', { 'with-effects': variant.modifiers.length > 0 }]} data-search={`${faction.displayName} ${variant.displayName} ${variant.id}`.toLowerCase()}>
                <span class="directory-icon">{variant.icon ? <GameIcon name={variant.icon} size={34} /> : <span>{variant.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{variant.displayName}</strong><code>{variant.id}</code>{variant.description && <small>{variant.description}</small>}</span>
                <ModifierBadges modifiers={variant.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : componentFamilies.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {componentFamilies.map((family) => (
        <section class="reform-option-group entry-group">
          <header><div><p class="eyebrow">Component Family</p><h2>{family.label}</h2></div><span>{family.entries.length} component{family.entries.length === 1 ? '' : 's'}</span></header>
          <div class="entry-directory">
            {family.entries.map((entry) => (
              <a href={withBase(`/unit-components/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${family.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <ModifierBadges modifiers={entry.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : technologyDomains.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {technologyDomains.map((domain) => (
        <section class="reform-option-group entry-group">
          <header><div><p class="eyebrow">Technology Domain</p><h2>{domain.label}</h2></div></header>
          <div class="entry-directory">
            {domain.entries.map((entry) => (
              <a href={withBase(`/technologies/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${domain.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <ModifierBadges modifiers={entry.modifiers} />
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : cultureDomains.length > 0 ? (
    <div class="grouped-directory culture-directory" id="entry-directory">
      {cultureDomains.map(({ domain, groups }) => (
        <section class="culture-domain">
          <header><p class="eyebrow">Culture Domain</p><h2>{domain}</h2></header>
          {groups.map(({ meta, entries: familyEntries }) => (
            <section class="reform-option-group culture-family entry-group">
              <header><div class="culture-family-title"><GameIcon name={meta.icon} size={30} /><div><p class="eyebrow">Trait Family</p><h3>{meta.label}</h3></div></div><a href={withBase(`/culture-traits/${meta.id}/`)}>View family</a></header>
              <div class="entry-directory">
                {[...familyEntries].sort((a, b) => Number(isCultureFamilyRoot(b.id)) - Number(isCultureFamilyRoot(a.id))).map((entry) => (
                  <a href={withBase(`/culture-traits/${meta.id}/#${entry.id}`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${domain} ${meta.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                    <span class="directory-icon"><GameIcon name={entry.icon ?? meta.icon} size={34} /></span>
                    <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                    <ModifierBadges modifiers={entry.modifiers} />
                    <span class="row-arrow" aria-hidden="true">›</span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </section>
      ))}
    </div>
  ) : (
    <div class="entry-directory" id="entry-directory">
      {entries.map((entry) => (
        <a href={withBase(`/${type}/${entry.id}/`)} class:list={['directory-row', { 'with-effects': entry.modifiers.length > 0 }]} data-search={`${entry.displayName} ${entry.id}`.toLowerCase()}>
          <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
          <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
          <ModifierBadges modifiers={entry.modifiers} />
          <span class="row-arrow" aria-hidden="true">›</span>
        </a>
      ))}
    </div>
  )}
  <p class="empty-state" id="empty-state" hidden>No entries match this filter.</p>
</BaseLayout>

<script>
  const filter = document.getElementById('entry-filter') as HTMLInputElement;
  const kind = document.getElementById('entry-kind') as HTMLSelectElement;
  const showIds = document.getElementById('show-ids') as HTMLInputElement;
  const directory = document.getElementById('entry-directory');
  const rows = [...document.querySelectorAll<HTMLElement>('.directory-row')];
  const count = document.getElementById('visible-count');
  const empty = document.getElementById('empty-state');
  const updateRows = () => {
    const query = filter.value.trim().toLowerCase();
    let visible = 0;
    rows.forEach((row) => {
      const matchesText = row.dataset.search?.includes(query) ?? false;
      const matchesKind = kind.value === 'all' || row.classList.contains('with-effects');
      const show = matchesText && matchesKind;
      row.hidden = !show;
      if (show) visible++;
    });
    document.querySelectorAll<HTMLElement>('.entry-group').forEach((group) => { group.hidden = !group.querySelector('.directory-row:not([hidden])'); });
    document.querySelectorAll<HTMLElement>('.culture-domain').forEach((domain) => { domain.hidden = !domain.querySelector('.entry-group:not([hidden])'); });
    if (count) count.textContent = `Showing ${visible}`;
    if (empty) empty.hidden = visible > 0;
  };
  filter?.addEventListener('input', updateRows);
  kind?.addEventListener('change', updateRows);
  const setIds = (visible: boolean) => {
    document.body.classList.toggle('hide-entry-ids', !visible);
    showIds.checked = visible;
    localStorage.setItem('wiki-show-ids', String(visible));
  };
  showIds?.addEventListener('change', () => setIds(showIds.checked));
  setIds(localStorage.getItem('wiki-show-ids') !== 'false');
  const setView = (view: string) => {
    document.querySelectorAll<HTMLButtonElement>('[data-view]').forEach((item) => {
      const active = item.dataset.view === view;
      item.classList.toggle('active', active);
      item.setAttribute('aria-pressed', String(active));
    });
    directory?.classList.toggle('compact', view === 'compact');
    directory?.querySelectorAll('.entry-directory').forEach((list) => list.classList.toggle('compact', view === 'compact'));
    localStorage.setItem('wiki-view', view);
  };
  document.querySelectorAll<HTMLButtonElement>('[data-view]').forEach((button) => button.addEventListener('click', () => {
    setView(button.dataset.view ?? 'comfortable');
  }));
  setView(localStorage.getItem('wiki-view') ?? 'comfortable');
</script>
