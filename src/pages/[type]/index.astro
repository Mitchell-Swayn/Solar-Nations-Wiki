---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameIcon from '../../components/GameIcon.astro';
import { getCategories, getEntriesByType } from '../../lib/data';
import { CATEGORY_BY_SLUG, CATEGORY_GROUPS } from '../../lib/categories';
import { getCultureTraitGroup } from '../../lib/culture';
import { withBase } from '../../lib/base';

export function getStaticPaths() {
  return getCategories().map((cat) => ({ params: { type: cat.slug } }));
}

const { type } = Astro.params;
const category = CATEGORY_BY_SLUG[type!];
if (category.mergedInto) return Astro.redirect(withBase(`/${category.mergedInto}/`));
const entries = getEntriesByType(type!).sort((a, b) => a.displayName.localeCompare(b.displayName));
const group = CATEGORY_GROUPS.find((item) => item.id === category.group);
const reforms = type === 'government-reforms' ? entries : [];
const reformOptionEntries = type === 'government-reforms' ? getEntriesByType('government-reform-options').sort((a, b) => a.displayName.localeCompare(b.displayName)) : [];
const reformGroups = reforms.map((reform) => {
  const optionIds = Array.isArray(reform.fields.Options) ? reform.fields.Options.filter((id): id is string => typeof id === 'string') : [];
  return { reform, options: optionIds.map((id) => reformOptionEntries.find((entry) => entry.id === id)).filter((entry) => entry !== undefined) };
});
const factionVariants = type === 'factions' ? getEntriesByType('faction-variants').sort((a, b) => a.displayName.localeCompare(b.displayName)) : [];
const factionGroups = type === 'factions' ? entries.map((faction) => ({
  faction,
  variants: factionVariants.filter((variant) => variant.fields.BaseFaction === faction.id),
})) : [];
const cultureGroups = type === 'culture-traits' ? Object.values(entries.reduce((groups, entry) => {
  const meta = getCultureTraitGroup(entry.id);
  groups[meta.id] ??= { meta, entries: [] };
  groups[meta.id].entries.push(entry);
  return groups;
}, {} as Record<string, { meta: ReturnType<typeof getCultureTraitGroup>; entries: typeof entries }>)) : [];
const cultureDomains = ['Species & Faith', 'Cultural', 'Economic', 'Diplomatic', 'Administrative', 'Military'].map((domain) => ({
  domain,
  groups: cultureGroups.filter((cultureGroup) => cultureGroup.meta.domain === domain).sort((a, b) => a.meta.label.localeCompare(b.meta.label)),
})).filter((domain) => domain.groups.length > 0);
const directoryCount = reformGroups.length > 0 ? reformOptionEntries.length : factionGroups.length > 0 ? factionVariants.length + entries.length : entries.length;
---

<BaseLayout title={category.pluralLabel} description={category.description} activeType={type}>
  <nav class="breadcrumb" aria-label="Breadcrumb"><a href={withBase('/')}>Wiki</a><span>/</span><span>{group?.label}</span><span>/</span><strong>{category.pluralLabel}</strong></nav>

  <header class="collection-header">
    <div><p class="eyebrow">{group?.label}</p><h1>{category.pluralLabel}</h1><p>{category.description}</p></div>
    <div class="collection-count"><strong>{directoryCount}</strong><span>{reformGroups.length > 0 ? `${reforms.length} reforms` : factionGroups.length > 0 ? `${entries.length} factions` : 'Entries'}</span></div>
  </header>

  <div class="collection-tools">
    <label class="filter-input"><span class="search-symbol"></span><input id="entry-filter" type="search" placeholder={`Filter ${category.pluralLabel.toLowerCase()}...`} /></label>
    <div class="view-switch" aria-label="View density">
      <button type="button" class="active" data-view="comfortable">List</button><button type="button" data-view="compact">Compact</button>
    </div>
    <span id="visible-count">Showing {directoryCount}</span>
  </div>

  {reformGroups.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {reformGroups.map(({ reform, options }) => (
        <section class="reform-option-group entry-group">
          <header><div><p class="eyebrow">Government Reform</p><h2>{reform.displayName}</h2></div><a href={withBase(`/government-reforms/${reform.id}/`)}>View reform</a></header>
          <div class="entry-directory">
            {options.map((entry) => (
              <a href={withBase(`/government-reform-options/${entry.id}/`)} class="directory-row" data-search={`${reform.displayName} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : factionGroups.length > 0 ? (
    <div class="grouped-directory" id="entry-directory">
      {factionGroups.map(({ faction, variants }) => (
        <section class="reform-option-group entry-group">
          <header><div class="culture-family-title">{faction.icon && <GameIcon name={faction.icon} size={30} />}<div><p class="eyebrow">Political Faction</p><h2>{faction.displayName}</h2></div></div><a href={withBase(`/factions/${faction.id}/`)}>View faction</a></header>
          <div class="entry-directory">
            <a href={withBase(`/factions/${faction.id}/`)} class="directory-row" data-search={`${faction.displayName} ${faction.id}`.toLowerCase()}>
              <span class="directory-icon">{faction.icon ? <GameIcon name={faction.icon} size={34} /> : <span>{faction.displayName.charAt(0)}</span>}</span>
              <span class="directory-main"><strong>{faction.displayName}</strong><code>{faction.id}</code>{faction.description && <small>{faction.description}</small>}</span>
              <span class="row-arrow" aria-hidden="true">›</span>
            </a>
            {variants.map((variant) => (
              <a href={withBase(`/faction-variants/${variant.id}/`)} class="directory-row" data-search={`${faction.displayName} ${variant.displayName} ${variant.id}`.toLowerCase()}>
                <span class="directory-icon">{variant.icon ? <GameIcon name={variant.icon} size={34} /> : <span>{variant.displayName.charAt(0)}</span>}</span>
                <span class="directory-main"><strong>{variant.displayName}</strong><code>{variant.id}</code>{variant.description && <small>{variant.description}</small>}</span>
                <span class="row-arrow" aria-hidden="true">›</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : cultureDomains.length > 0 ? (
    <div class="grouped-directory culture-directory" id="entry-directory">
      {cultureDomains.map(({ domain, groups }) => (
        <section class="culture-domain">
          <header><p class="eyebrow">Culture Domain</p><h2>{domain}</h2></header>
          {groups.map(({ meta, entries: familyEntries }) => (
            <section class="reform-option-group culture-family entry-group">
              <header><div class="culture-family-title"><GameIcon name={meta.icon} size={30} /><div><p class="eyebrow">Trait Family</p><h3>{meta.label}</h3></div></div><span>{familyEntries.length} ideas</span></header>
              <div class="entry-directory">
                {familyEntries.map((entry) => (
                  <a href={withBase(`/${type}/${entry.id}/`)} class="directory-row" data-search={`${domain} ${meta.label} ${entry.displayName} ${entry.id}`.toLowerCase()}>
                    <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
                    <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
                    <span class="row-arrow" aria-hidden="true">›</span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </section>
      ))}
    </div>
  ) : (
    <div class="entry-directory" id="entry-directory">
      {entries.map((entry) => (
        <a href={withBase(`/${type}/${entry.id}/`)} class="directory-row" data-search={`${entry.displayName} ${entry.id}`.toLowerCase()}>
          <span class="directory-icon">{entry.icon ? <GameIcon name={entry.icon} size={34} /> : <span>{entry.displayName.charAt(0)}</span>}</span>
          <span class="directory-main"><strong>{entry.displayName}</strong><code>{entry.id}</code>{entry.description && <small>{entry.description}</small>}</span>
          <span class="row-arrow" aria-hidden="true">›</span>
        </a>
      ))}
    </div>
  )}
  <p class="empty-state" id="empty-state" hidden>No entries match this filter.</p>
</BaseLayout>

<script>
  const filter = document.getElementById('entry-filter') as HTMLInputElement;
  const directory = document.getElementById('entry-directory');
  const rows = [...document.querySelectorAll<HTMLElement>('.directory-row')];
  const count = document.getElementById('visible-count');
  const empty = document.getElementById('empty-state');
  filter?.addEventListener('input', () => {
    const query = filter.value.trim().toLowerCase();
    let visible = 0;
    rows.forEach((row) => { const show = row.dataset.search?.includes(query) ?? false; row.hidden = !show; if (show) visible++; });
    document.querySelectorAll<HTMLElement>('.entry-group').forEach((group) => { group.hidden = !group.querySelector('.directory-row:not([hidden])'); });
    document.querySelectorAll<HTMLElement>('.culture-domain').forEach((domain) => { domain.hidden = !domain.querySelector('.entry-group:not([hidden])'); });
    if (count) count.textContent = `Showing ${visible}`;
    if (empty) empty.hidden = visible > 0;
  });
  document.querySelectorAll<HTMLButtonElement>('[data-view]').forEach((button) => button.addEventListener('click', () => {
    document.querySelectorAll('[data-view]').forEach((item) => item.classList.remove('active'));
    button.classList.add('active');
    directory?.classList.toggle('compact', button.dataset.view === 'compact');
    directory?.querySelectorAll('.entry-directory').forEach((list) => list.classList.toggle('compact', button.dataset.view === 'compact'));
  }));
</script>
