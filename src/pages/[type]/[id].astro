---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import StatTable from '../../components/StatTable.astro';
import ModifierList from '../../components/ModifierList.astro';
import FactionPrivilegeEffects from '../../components/FactionPrivilegeEffects.astro';
import PrerequisiteChain from '../../components/PrerequisiteChain.astro';
import GameIcon from '../../components/GameIcon.astro';
import CountryFlagIcon from '../../components/CountryFlagIcon.astro';
import CultureTraitFamilies from '../../components/CultureTraitFamilies.astro';
import CultureCountries from '../../components/CultureCountries.astro';
import CharacterJobSkillBonuses from '../../components/CharacterJobSkillBonuses.astro';
import ScenarioTabs from '../../components/ScenarioTabs.astro';
import RegionScenarioList from '../../components/RegionScenarioList.astro';
import { getCategories, getEntry, getEntriesByType } from '../../lib/data';
import { getCountryScenarios, getCultureIconCountry } from '../../lib/countries';
import { CATEGORY_BY_SLUG, CATEGORY_GROUPS } from '../../lib/categories';
import { withBase } from '../../lib/base';

export function getStaticPaths() {
  // Culture traits are served by grouped family pages at /culture-traits/[family]/
  return getCategories().filter((cat) => !['culture-traits', 'countries', 'regions'].includes(cat.slug)).flatMap((cat) => getEntriesByType(cat.slug).map((entry) => ({ params: { type: cat.slug, id: entry.id } })));
}

const { type, id } = Astro.params;
const entry = getEntry(type!, id!);
const category = CATEGORY_BY_SLUG[type!];
const mergedCategory = category.mergedInto ? CATEGORY_BY_SLUG[category.mergedInto] : undefined;
if (!entry) return Astro.redirect(withBase(`/${type}/`));
const breadcrumbCategory = mergedCategory ?? category;
const group = CATEGORY_GROUPS.find((item) => item.id === breadcrumbCategory.group);
const entries = getEntriesByType(type!);
const position = entries.findIndex((item) => item.id === entry.id);
const previous = position > 0 ? entries[position - 1] : undefined;
const next = position < entries.length - 1 ? entries[position + 1] : undefined;
const optionIds = type === 'government-reforms' && Array.isArray(entry.fields.Options) ? entry.fields.Options.filter((value): value is string => typeof value === 'string') : [];
const reformOptions = optionIds.map((optionId) => getEntry('government-reform-options', optionId)).filter((option) => option !== undefined);
const factionVariants = type === 'factions' ? getEntriesByType('faction-variants').filter((variant) => variant.fields.BaseFaction === entry.id) : [];
const privilegeFaction = type === 'faction-privileges' && typeof entry.fields.Faction === 'string'
  ? getEntry('factions', entry.fields.Faction)
  : undefined;
const cultureScenarioStates = type === 'cultures' ? getCountryScenarios().flatMap((scenario) => {
  const culture = scenario.cultures.find((item) => item.id === entry.id);
  if (!culture) return [];
  const countries = scenario.countries.flatMap((country) => {
    const governmentRelationship = country.primaryCulture === entry.id
      ? 'Primary' as const
      : country.promotedCultures.includes(entry.id)
        ? 'Promoted' as const
        : country.oppressedCultures.includes(entry.id)
          ? 'Oppressed' as const
          : country.acceptedCultures.includes(entry.id)
            ? 'Accepted' as const
            : undefined;
    const geographicRegions = country.regions.flatMap((region) => {
      const cultureShare = region.cultures.find((item) => item.id === entry.id)?.share ?? 0;
      return cultureShare > 0 ? [{ region, cultureShare }] : [];
    });
    const culturePopulation = geographicRegions.reduce((sum, item) => sum + item.region.population * item.cultureShare, 0);
    const relationship = governmentRelationship ?? (culturePopulation > 0 ? 'Present' as const : undefined);
    return relationship ? [{
      country,
      relationship,
      culturePopulation,
      cultureShare: country.population > 0 ? culturePopulation / country.population : 0,
      regionCount: geographicRegions.length,
    }] : [];
  }).sort((left, right) => {
    const priority = { Primary: 0, Promoted: 1, Accepted: 2, Oppressed: 3, Present: 4 };
    return priority[left.relationship] - priority[right.relationship]
      || right.culturePopulation - left.culturePopulation
      || left.country.name.localeCompare(right.country.name);
  });
  return [{ scenarioId: scenario.id, scenarioName: scenario.name, traitIds: culture.traits, countries }];
}) : [];
const cultureScenarioTabs = cultureScenarioStates.map((state, index) => ({
  id: state.scenarioId,
  label: state.scenarioName,
  href: `?scenario=${state.scenarioId}`,
  active: index === 0,
}));
const cultureFlagStates = cultureScenarioStates.map((state) => ({
  scenarioId: state.scenarioId,
  country: getCultureIconCountry(entry.id, state.scenarioId),
}));
const hasCultureFlag = cultureFlagStates.some((state) => state.country);
const privilegeEffectFields = new Set(['StabilityGain', 'StabilityMaintenance', 'PowerChange', 'LoyaltyImpact']);
const detailFields = Object.fromEntries(Object.entries(entry.fields).filter(([key]) => key !== 'Options' && !(type === 'cultures' && key === 'Traits') && !(type === 'faction-privileges' && privilegeEffectFields.has(key))));
const propertyCount = Object.keys(detailFields).filter((key) => !['Name', 'Icon'].includes(key)).length;
---

<BaseLayout title={`${entry.displayName} — ${category.pluralLabel}`} description={entry.description} activeType={category.mergedInto ?? type}>
  <Breadcrumbs group={group?.label} category={breadcrumbCategory.pluralLabel} categoryHref={`/${category.mergedInto ?? type}/`} current={entry.displayName} />

  <article class:list={['article-layout', { 'planetary-body-article': type === 'planetary-bodies' }]}>
    <div class="article-main">
      <header class="article-header">
        <p class="eyebrow">{group?.label} · {category.label}</p>
        <div class="article-title">
          {type === 'cultures' && hasCultureFlag ? (
            cultureFlagStates.map((state, index) => state.country && (
              <span class="article-icon" data-scenario-panel={state.scenarioId} hidden={index > 0}><CountryFlagIcon flag={state.country.flag} countryName={state.country.name} size={56} loading="eager" fetchpriority="high" /></span>
            ))
          ) : entry.icon && <span class="article-icon"><GameIcon name={entry.icon} size={56} loading="eager" fetchpriority="high" /></span>}
          <div><h1>{entry.displayName}</h1><code>{entry.id}</code></div>
        </div>
        {entry.description ? <p class="article-lede">{entry.description}</p> : <p class="article-lede muted">A {category.label.toLowerCase()} definition from the Solar Nations 2 game data.</p>}
      </header>

      {cultureScenarioTabs.length > 0 && <ScenarioTabs tabs={cultureScenarioTabs} switchPanels />}

      {type === 'planetary-bodies' && <RegionScenarioList planetId={entry.id} />}
      {type === 'deposits' && <RegionScenarioList depositId={entry.id} />}

      {entry.prerequisites.length > 0 && <section class="article-section" id="requirements"><h2>Requirements</h2><PrerequisiteChain prerequisites={entry.prerequisites} /></section>}
      {reformOptions.length > 0 && <section class="article-section" id="options"><h2>Reform options</h2><div class="related-options">{reformOptions.map((option) => <a href={withBase(`/government-reform-options/${option.id}/`)}>{option.icon && <GameIcon name={option.icon} size={30} />}<span><strong>{option.displayName}</strong><code>{option.id}</code></span><b>›</b></a>)}</div></section>}
      {factionVariants.length > 0 && <section class="article-section" id="variants"><h2>Faction variants</h2><div class="related-options">{factionVariants.map((variant) => <a href={withBase(`/faction-variants/${variant.id}/`)}>{variant.icon && <GameIcon name={variant.icon} size={30} />}<span><strong>{variant.displayName}</strong><code>{variant.id}</code></span><b>›</b></a>)}</div></section>}
      {cultureScenarioStates.length > 0 && (
        <section class="article-section" id="countries">
          <h2>Countries</h2>
          {cultureScenarioStates.map((state, index) => (
            <div data-scenario-panel={state.scenarioId} hidden={index > 0}>
              <CultureCountries scenarioId={state.scenarioId} countries={state.countries} />
            </div>
          ))}
        </section>
      )}
      {cultureScenarioStates.length > 0 && (
        <section class="article-section" id="traits">
          <h2>Culture traits</h2>
          {cultureScenarioStates.map((state, index) => (
            <div id={`scenario-panel-${state.scenarioId}`} data-scenario-panel={state.scenarioId} hidden={index > 0}>
              <CultureTraitFamilies traitIds={state.traitIds} />
            </div>
          ))}
        </section>
      )}
      {type === 'faction-privileges' ? (
        <section class="article-section" id="effects"><h2>Gameplay effects</h2><FactionPrivilegeEffects fields={entry.fields} modifiers={entry.modifiers} faction={privilegeFaction} /></section>
      ) : entry.modifiers.length > 0 && <section class="article-section" id="effects"><h2>Gameplay effects</h2><ModifierList modifiers={entry.modifiers} /></section>}
      {type === 'character-jobs' && entry.skillModifiers && (
        <section class="article-section" id="skill-bonuses">
          <h2>Bonuses per skill level</h2>
          <CharacterJobSkillBonuses skillModifiers={entry.skillModifiers} />
        </section>
      )}
      {propertyCount > 0 && <section class="article-section" id="properties"><h2>Properties</h2><StatTable data={detailFields} /></section>}
      {propertyCount === 0 && entry.modifiers.length === 0 && cultureScenarioStates.length === 0 && <section class="article-section"><h2>Data availability</h2><p class="notice">This entry is present in the game definitions, but no additional structured properties were available in the current extraction.</p></section>}

      <nav class="article-pager" aria-label="Adjacent entries">
        {previous ? <a href={withBase(`/${type}/${previous.id}/`)}><small>Previous</small><strong>‹ {previous.displayName}</strong></a> : <span></span>}
        {next && <a href={withBase(`/${type}/${next.id}/`)} class="next"><small>Next</small><strong>{next.displayName} ›</strong></a>}
      </nav>
    </div>

  </article>
</BaseLayout>
