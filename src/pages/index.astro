---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCategories, getAllEntries, getEntriesByType } from '../lib/data';
import { CATEGORY_GROUPS } from '../lib/categories';
import { withBase } from '../lib/base';
import GameIcon from '../components/GameIcon.astro';

const categories = getCategories().filter((category) => !category.mergedInto);
const allEntries = getAllEntries();
const featured = ['technologies', 'government-reforms', 'projects', 'factions', 'unit-components', 'resources'];
const featuredIcons: Record<string, string> = {
  technologies: 'eraInformation',
  'government-reforms': 'gavel',
  projects: 'development',
  factions: 'political',
  'unit-components': 'defense',
  resources: 'currency',
};
---

<BaseLayout title="Solar Nations 2 Wiki" description="Strategy and game data encyclopedia for Solar Nations 2">
  <header class="overview-header">
    <div class="hero-orbits" aria-hidden="true"><span></span><span></span><span></span></div>
    <div>
      <p class="eyebrow">Community Reference</p>
      <h1>Solar Nations 2 Strategy Wiki</h1>
      <p>Explore the systems behind interplanetary government, research, industry, society, and warfare.</p>
    </div>
    <dl class="dataset-summary">
      <div><dt>Entries</dt><dd>{allEntries.length.toLocaleString()}</dd></div>
      <div><dt>Categories</dt><dd>{categories.length}</dd></div>
      <div><dt>Source</dt><dd>Game files</dd></div>
    </dl>
  </header>

  <section class="start-section">
    <div class="section-heading"><div><p class="eyebrow">Quick Access</p><h2>Core game systems</h2></div></div>
    <div class="feature-grid">
      {featured.map((slug) => {
        const cat = categories.find((item) => item.slug === slug)!;
        return (
          <a href={withBase(`/${cat.slug}/`)} class="feature-link">
            <span class="feature-icon"><GameIcon name={featuredIcons[slug]} size={32} /></span>
            <div><h3>{cat.pluralLabel}</h3><p>{cat.description}</p></div>
            <strong>{getEntriesByType(slug).length}</strong>
          </a>
        );
      })}
    </div>
  </section>

  <section class="pathway-section">
    <div class="section-heading"><div><p class="eyebrow">Find your way</p><h2>Browse by goal</h2></div><p>Start with the part of your nation you want to understand.</p></div>
    <div class="pathway-grid">
      <a href={withBase('/technologies/')}><small>Research</small><strong>Plan your technology path</strong><span>Technologies, requirements, and effects ›</span></a>
      <a href={withBase('/government-reforms/')}><small>Society</small><strong>Shape government and culture</strong><span>Reforms, factions, and cultural traits ›</span></a>
      <a href={withBase('/resources/')}><small>Economy</small><strong>Understand production</strong><span>Resources, projects, and deposits ›</span></a>
      <a href={withBase('/unit-components/')}><small>Military</small><strong>Design and expand</strong><span>Components, eras, and strategic sites ›</span></a>
    </div>
  </section>

  <section class="browse-section">
    <div class="section-heading"><div><p class="eyebrow">Encyclopedia</p><h2>Browse by domain</h2></div><p>All extracted game definitions, organized around player decisions.</p></div>
    <div class="domain-list">
      {CATEGORY_GROUPS.map((group) => (
        <section class="domain-block">
          <header><h3>{group.label}</h3><p>{group.description}</p></header>
          <div>
            {categories.filter((cat) => cat.group === group.id).map((cat) => (
              <a href={withBase(`/${cat.slug}/`)}><span>{cat.pluralLabel}</span><small>{getEntriesByType(cat.slug).length}</small></a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
