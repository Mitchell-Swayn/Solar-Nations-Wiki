---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameIcon from '../components/GameIcon.astro';
import { getAllEntries, getCategories, getCategoryCount } from '../lib/data';
import { getCountryScenarios } from '../lib/countries';
import { CATEGORY_GROUPS } from '../lib/categories';
import { withBase } from '../lib/base';

const categories = getCategories().filter((category) => !category.mergedInto);
const scenarios = getCountryScenarios();
const entryCount = getAllEntries().length + getCategoryCount('countries');
const compactNumber = new Intl.NumberFormat('en', { notation: 'compact', maximumFractionDigits: 1 });

const gateways = [
  { slug: 'countries', icon: 'political', label: 'Countries', description: 'Compare starting nations, governments, cultures, economies, and territory.' },
  { slug: 'regions', icon: 'territory', label: 'Regions', description: 'Explore populated regions, colonies, orbital sites, terrain, and deposits.' },
  { slug: 'cultures', icon: 'cultureCircle', label: 'Cultures', description: 'See where cultures are present and which trait families define them.' },
  { slug: 'planetary-bodies', icon: 'planet', label: 'Planetary Bodies', description: 'Browse worlds, moons, minor bodies, and their starting regions.' },
];

const scenarioIcons: Record<string, string> = {
  'age-of-information': 'eraInformation',
  'twilight-of-modernity': 'eraUnraveling',
};

const groupIcons: Record<string, string> = {
  nations: 'political',
  world: 'planet',
  society: 'gavel',
  core: 'currency',
  characters: 'leader',
  military: 'defense',
  diplomacy: 'diplomacy',
  progression: 'eraInformation',
  reference: 'research',
};
---

<BaseLayout title="Solar Nations 2 Wiki" description="Strategy and game data encyclopedia for Solar Nations 2">
  <header class="overview-hero">
    <div class="hero-copy">
      <p class="eyebrow">Community game reference</p>
      <h1>Solar Nations 2 Wiki</h1>
      <p class="hero-lede">Explore the nations, worlds, cultures, and interconnected systems of Solar Nations 2 through data extracted from the base game.</p>
      <div class="hero-actions">
        <a class="primary" href={withBase('/countries/')}>Browse countries <span aria-hidden="true">›</span></a>
        <a href={withBase('/regions/')}>Explore the map <span aria-hidden="true">›</span></a>
      </div>
    </div>
    <dl class="overview-stats">
      <div><dt>Wiki entries</dt><dd>{entryCount.toLocaleString()}</dd></div>
      <div><dt>Categories</dt><dd>{categories.length}</dd></div>
      <div><dt>Scenarios</dt><dd>{scenarios.length}</dd></div>
      <div><dt>Source</dt><dd>Base game</dd></div>
    </dl>
    <div class="hero-orbits" aria-hidden="true"><span></span><span></span><span></span></div>
  </header>

  <section class="overview-section gateway-section" aria-labelledby="start-heading">
    <header class="overview-section-heading">
      <div><p class="eyebrow">Start exploring</p><h2 id="start-heading">The world at game start</h2></div>
      <p>Begin with the entities shown directly on the campaign map.</p>
    </header>
    <div class="gateway-grid">
      {gateways.map((gateway) => (
        <a class="gateway-card" href={withBase(`/${gateway.slug}/`)}>
          <span class="gateway-icon"><GameIcon name={gateway.icon} size={38} /></span>
          <span class="gateway-copy"><strong>{gateway.label}</strong><small>{gateway.description}</small></span>
          <span class="gateway-count"><b>{getCategoryCount(gateway.slug).toLocaleString()}</b><small>entries</small></span>
          <span class="gateway-arrow" aria-hidden="true">›</span>
        </a>
      ))}
    </div>
  </section>

  <section class="overview-section scenario-section" aria-labelledby="scenario-heading">
    <header class="overview-section-heading">
      <div><p class="eyebrow">Starting scenarios</p><h2 id="scenario-heading">Choose a point in history</h2></div>
      <p>Country, culture, and territorial configurations are preserved separately for each scenario.</p>
    </header>
    <div class="scenario-grid">
      {scenarios.map((scenario) => {
        const population = scenario.regions.reduce((total, region) => total + region.population, 0);
        return (
          <a class="scenario-card" href={`${withBase('/countries/')}?scenario=${encodeURIComponent(scenario.id)}`} data-scenario-id={scenario.id}>
            <span class="scenario-icon"><GameIcon name={scenarioIcons[scenario.id] ?? 'eraInformation'} size={46} /></span>
            <span class="scenario-copy">
              <small>Base-game scenario</small>
              <strong>{scenario.name}</strong>
              <span>{scenario.countries.length} countries · {scenario.regions.length} regions · {compactNumber.format(population)} population</span>
            </span>
            <span class="scenario-content"><b>{scenario.selectableCount}</b><small>content nations</small></span>
            <span class="scenario-arrow" aria-hidden="true">›</span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="overview-section encyclopedia-section" aria-labelledby="encyclopedia-heading">
    <header class="overview-section-heading">
      <div><p class="eyebrow">Complete reference</p><h2 id="encyclopedia-heading">Browse the encyclopedia</h2></div>
      <p>Player-facing game definitions arranged in the same domains as the wiki navigation.</p>
    </header>
    <div class="encyclopedia-grid">
      {CATEGORY_GROUPS.map((group) => {
        const groupCategories = categories.filter((category) => category.group === group.id);
        return (
          <section class="encyclopedia-card">
            <header>
              <span><GameIcon name={groupIcons[group.id] ?? 'research'} size={30} /></span>
              <div><h3>{group.label}</h3><p>{group.description}</p></div>
            </header>
            <nav aria-label={group.label}>
              {groupCategories.map((category) => (
                <a href={withBase(`/${category.slug}/`)}><span>{category.pluralLabel}</span><small>{getCategoryCount(category.slug).toLocaleString()}</small></a>
              ))}
            </nav>
          </section>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .overview-hero { position: relative; display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: end; gap: 48px; overflow: hidden; min-height: 330px; padding: 48px 42px 40px; color: #dce7e5; background: linear-gradient(125deg, var(--ink) 0%, #203940 67%, #2b5151 100%); border-bottom: 3px solid var(--accent); border-radius: var(--radius); }
  .hero-copy, .overview-stats { position: relative; z-index: 1; }
  .overview-hero .eyebrow { color: #f0a548; }
  .overview-hero h1 { max-width: 760px; margin: 0 0 15px; color: #fff; font-size: clamp(38px, 5vw, 64px); line-height: .98; }
  .hero-lede { max-width: 720px; margin: 0; color: #becdcb; font-size: 16px; line-height: 1.65; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 25px; }
  .hero-actions a { display: inline-flex; align-items: center; justify-content: space-between; gap: 18px; min-width: 155px; padding: 10px 13px; color: #e5eeee; border: 1px solid #607477; border-radius: 4px; font-size: 11px; font-weight: 700; }
  .hero-actions a:hover { color: #fff; background: rgb(255 255 255 / 7%); border-color: #94a8a8; }
  .hero-actions a.primary { color: #1d2b30; background: var(--accent); border-color: var(--accent); }
  .hero-actions a.primary:hover { background: #efaa50; }
  .hero-actions span { font-size: 17px; line-height: 1; }
  .overview-stats { display: grid; grid-template-columns: repeat(2, minmax(104px, 1fr)); width: 270px; margin: 0; border-top: 1px solid #53676a; border-left: 1px solid #53676a; }
  .overview-stats div { min-height: 82px; padding: 14px 16px; border-right: 1px solid #53676a; border-bottom: 1px solid #53676a; }
  .overview-stats dt { color: #9fb1b0; font-size: 8px; font-weight: 700; letter-spacing: .11em; text-transform: uppercase; }
  .overview-stats dd { margin: 7px 0 0; color: #fff; font-family: var(--display); font-size: 19px; font-weight: 600; }
  .hero-orbits { position: absolute; inset: 0; pointer-events: none; opacity: .36; }
  .hero-orbits span { position: absolute; right: -100px; top: 44%; width: 390px; height: 170px; border: 1px solid #7ca5a2; border-radius: 50%; transform: rotate(-18deg); }
  .hero-orbits span:nth-child(2) { right: 85px; top: 18%; width: 190px; height: 190px; border-color: #d58a31; }
  .hero-orbits span:nth-child(3) { right: 164px; top: 46%; width: 14px; height: 14px; background: #efaa50; border: 0; box-shadow: 0 0 28px #efaa50; }

  .overview-section { padding-top: 42px; }
  .overview-section-heading { display: flex; align-items: end; justify-content: space-between; gap: 40px; margin-bottom: 18px; }
  .overview-section-heading h2 { margin: 0; font-size: 25px; }
  .overview-section-heading > p { max-width: 450px; margin: 0; color: var(--text-muted); font-size: 11px; line-height: 1.6; text-align: right; }

  .gateway-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); border-top: 1px solid var(--border-strong); border-left: 1px solid var(--border-strong); }
  .gateway-card { display: grid; grid-template-columns: 54px minmax(0, 1fr) auto 12px; align-items: center; gap: 15px; min-height: 112px; padding: 18px; color: var(--text); background: var(--surface); border-right: 1px solid var(--border-strong); border-bottom: 1px solid var(--border-strong); }
  .gateway-card:hover { z-index: 1; color: var(--text); background: #f8faf9; box-shadow: inset 3px 0 0 var(--accent); }
  .gateway-icon { display: grid; place-items: center; width: 52px; height: 52px; background: var(--surface-2); border: 1px solid var(--border); border-radius: 50%; }
  .gateway-copy, .gateway-copy strong, .gateway-copy small, .gateway-count small { display: block; }
  .gateway-copy strong { margin-bottom: 5px; font-family: var(--display); font-size: 17px; }
  .gateway-copy small { max-width: 380px; color: var(--text-muted); font-size: 10px; line-height: 1.5; }
  .gateway-count { min-width: 54px; text-align: right; }
  .gateway-count b { color: var(--teal); font-family: var(--mono); font-size: 13px; }
  .gateway-count small { margin-top: 2px; color: var(--text-muted); font-size: 8px; text-transform: uppercase; }
  .gateway-arrow, .scenario-arrow { color: var(--border-strong); font-size: 21px; }

  .scenario-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  .scenario-card { display: grid; grid-template-columns: 58px minmax(0, 1fr) auto 12px; align-items: center; gap: 15px; min-height: 128px; padding: 19px; color: var(--text); background: var(--surface); border: 1px solid var(--border); border-top: 3px solid var(--teal); border-radius: var(--radius); }
  .scenario-card:hover { color: var(--text); border-top-color: var(--accent); box-shadow: 0 9px 25px rgb(23 32 38 / 8%); transform: translateY(-2px); }
  .scenario-icon { display: grid; place-items: center; width: 56px; height: 56px; background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius); }
  .scenario-copy, .scenario-copy small, .scenario-copy strong, .scenario-copy span, .scenario-content small { display: block; min-width: 0; }
  .scenario-copy > small { margin-bottom: 4px; color: var(--accent-dark); font-size: 8px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
  .scenario-copy strong { overflow: hidden; margin-bottom: 6px; font-family: var(--display); font-size: 17px; text-overflow: ellipsis; white-space: nowrap; }
  .scenario-copy span { color: var(--text-muted); font-size: 9px; }
  .scenario-content { min-width: 68px; text-align: right; }
  .scenario-content b { color: var(--ink); font-family: var(--display); font-size: 19px; }
  .scenario-content small { margin-top: 2px; color: var(--text-muted); font-size: 8px; text-transform: uppercase; }

  .encyclopedia-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }
  .encyclopedia-card { overflow: hidden; background: var(--surface); border: 1px solid var(--border); border-top: 3px solid var(--ink-2); border-radius: 2px; }
  .encyclopedia-card > header { display: grid; grid-template-columns: 38px minmax(0, 1fr); gap: 11px; min-height: 105px; padding: 16px; background: var(--surface-2); border-bottom: 1px solid var(--border); }
  .encyclopedia-card > header > span { display: grid; place-items: center; width: 36px; height: 36px; background: var(--surface); border: 1px solid var(--border); border-radius: 50%; }
  .encyclopedia-card h3 { margin: 0 0 6px; font-size: 15px; }
  .encyclopedia-card header p { margin: 0; color: var(--text-muted); font-size: 9px; line-height: 1.5; }
  .encyclopedia-card nav a { display: flex; justify-content: space-between; gap: 14px; padding: 9px 13px; color: var(--text); border-bottom: 1px solid var(--border); font-size: 10px; }
  .encyclopedia-card nav a:last-child { border-bottom: 0; }
  .encyclopedia-card nav a:hover { color: var(--accent-dark); background: #f6f8f7; }
  .encyclopedia-card nav small { color: var(--text-muted); font-family: var(--mono); }

  @media (max-width: 1100px) {
    .overview-hero { align-items: start; grid-template-columns: 1fr; }
    .overview-stats { width: min(100%, 520px); }
    .encyclopedia-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 760px) {
    .overview-hero { min-height: 0; margin: -10px -6px 0; padding: 34px 24px; }
    .overview-section-heading { display: block; }
    .overview-section-heading > p { margin-top: 8px; text-align: left; }
    .gateway-grid, .scenario-grid, .encyclopedia-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 500px) {
    .overview-hero h1 { font-size: 38px; }
    .overview-stats { grid-template-columns: repeat(2, 1fr); }
    .overview-stats div { min-width: 0; }
    .gateway-card { grid-template-columns: 48px minmax(0, 1fr) 10px; min-height: 100px; padding: 14px; }
    .gateway-icon { width: 46px; height: 46px; }
    .gateway-count { display: none; }
    .scenario-card { grid-template-columns: 50px minmax(0, 1fr) 10px; padding: 15px; }
    .scenario-icon { width: 48px; height: 48px; }
    .scenario-content { display: none; }
  }
</style>
